{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/internet-ostrava", "destination": "/", "permanent": true },
    { "source": "/poda", "destination": "/poda-internet-ostrava/", "permanent": true },
    { "source": "/poda-internet", "destination": "/poda-internet-ostrava/", "permanent": true },
    { "source": "/poda-ostrava", "destination": "/poda-internet-ostrava/", "permanent": true },
    { "source": "/poda-pokryti", "destination": "/poda-dostupnost/", "permanent": true },
    { "source": "/poda-overeni-dostupnosti", "destination": "/poda-dostupnost/", "permanent": true },
    { "source": "/poda-internet-karvina", "destination": "/poda-karvina/", "permanent": true },
    { "source": "/internet-karvina", "destination": "/poda-karvina/", "permanent": true },
    { "source": "/poda-poruba", "destination": "/internet-ostrava-poruba/", "permanent": true },
    { "source": "/poda-internet-poruba", "destination": "/internet-ostrava-poruba/", "permanent": true },
    { "source": "/internet-poruba", "destination": "/internet-ostrava-poruba/", "permanent": true },
    { "source": "/internet-vitkovice", "destination": "/internet-ostrava-vitkovice/", "permanent": true },
    { "source": "/vitkovice", "destination": "/internet-ostrava-vitkovice/", "permanent": true },
    { "source": "/internet-hrabuvka", "destination": "/internet-ostrava-jih/", "permanent": true },
    { "source": "/internet-zabreh", "destination": "/internet-ostrava-jih/", "permanent": true }
  ]
}
